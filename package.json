{
  "name": "galaxy-token",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "description": "Fixed-supply Galaxy (GXLY) ERC-20 token",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run typecheck && pnpm run compile --build-profile production && pnpm test && pnpm audit --audit-level=high",
    "test:solidity": "hardhat test solidity",
    "deploy:local": "hardhat ignition deploy ignition/modules/Galaxy.ts --network hardhatOp --parameters ignition/parameters/local.json --build-profile production",
    "deploy:base-sepolia": "hardhat ignition deploy ignition/modules/Galaxy.ts --network baseSepolia",
    "deploy:base-sepolia:reset": "hardhat ignition deploy ignition/modules/Galaxy.ts --network baseSepolia --reset",
    "verify:base-sepolia": "hardhat ignition verify chain-84532",
    "preflight:base-mainnet": "node scripts/preflight.mjs",
    "deploy:base-mainnet": "pnpm run preflight:base-mainnet && hardhat ignition deploy ignition/modules/Galaxy.ts --network baseMainnet",
    "verify:base-mainnet": "hardhat ignition verify chain-8453"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.15",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.11",
    "@nomicfoundation/hardhat-ignition": "^3.1.8",
    "@nomicfoundation/hardhat-ignition-ethers": "^3.1.6",
    "@nomicfoundation/hardhat-keystore": "^3.0.12",
    "@nomicfoundation/hardhat-mocha": "^3.0.21",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.11",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@nomicfoundation/hardhat-typechain": "^3.1.1",
    "@nomicfoundation/hardhat-verify": "^3.0.21",
    "@nomicfoundation/ignition-core": "^3.1.8",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "^8.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.8.5",
    "chai": "^6.2.2",
    "ethers": "^6.14.0",
    "hardhat": "^3.10.0",
    "mocha": "^11.0.0",
    "typescript": "~6.0.3"
  }
}
