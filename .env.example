# Base Sepolia RPC endpoint. The public endpoint below is suitable for testing,
# but a dedicated provider is more reliable for repeated deployments.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Use a dedicated test-only wallet. Never commit or share this value.
BASE_SEPOLIA_PRIVATE_KEY=0xYOUR_TEST_WALLET_PRIVATE_KEY

# Use a dedicated mainnet RPC endpoint. Deployment spends real ETH.
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# Prefer a hardware-backed deployment wallet. Never commit this value.
BASE_MAINNET_PRIVATE_KEY=0xYOUR_MAINNET_DEPLOYER_PRIVATE_KEY

# Etherscan V2 API key used to verify contracts on BaseScan.
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
